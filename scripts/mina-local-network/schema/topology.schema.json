{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://mina.protocol/topology.schema.json",
  "title": "Mina Local Network Topology",
  "description": "Topology definition for mina-local-network.py v1",
  "type": "object",
  "required": ["schema_version", "ledger_generation", "nodes"],
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "type": "integer",
      "description": "Topology schema version (1 for v1)",
      "const": 1
    },
    "name": {
      "type": "string",
      "description": "Human-readable name for this topology"
    },
    "description": {
      "type": "string",
      "description": "Human-readable description"
    },
    "runtime_config": {
      "type": "object",
      "description": "Mina daemon config overrides. ledger and genesis.genesis_state_timestamp are forbidden (generated by local-network).",
      "additionalProperties": false,
      "properties": {
        "genesis": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "slots_per_epoch": { "type": "integer" },
            "k": { "type": "integer" },
            "grace_period_slots": { "type": "integer" }
          }
        },
        "proof": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "level": { "type": "string", "enum": ["full", "check", "none"] },
            "work_delay": { "type": "integer" },
            "transaction_capacity": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "2_to_the": { "type": "integer" }
              }
            },
            "block_window_duration_ms": { "type": "integer" }
          }
        },
        "daemon": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "slot_tx_end": { "type": "integer" },
            "slot_chain_end": { "type": "integer" },
            "hard_fork_genesis_slot_delta": { "type": "integer" }
          }
        }
      }
    },
    "ledger_generation": {
      "type": "object",
      "description": "Ledger account generation configuration.  Consensus/proof values (proof_level, slots_per_epoch, k, grace_period_slots, work_delay, transaction_capacity) belong under runtime_config — they must not be duplicated here.",
      "required": ["tiers"],
      "additionalProperties": false,
      "properties": {
        "tiers": {
          "type": "object",
          "description": "Tier definitions. Keys are tier names: whale, fish, snark_coordinator, service, custom.",
          "additionalProperties": {
            "type": "object",
            "required": ["count"],
            "additionalProperties": false,
            "properties": {
              "count": { "type": "integer", "minimum": 0 },
              "offline_balance": {
                "type": "string",
                "description": "Offline account balance, e.g. '11550000mina'"
              },
              "online_balance": {
                "type": "string",
                "description": "Online account balance, e.g. '499nanomina'"
              }
            }
          }
        },
        "accounts": {
          "type": "object",
          "description": "Named extra accounts beyond tiers, e.g. snark-fee account",
          "additionalProperties": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "balance": {
                "type": "string",
                "description": "Account balance, e.g. '1000nanomina'"
              },
              "kind": {
                "type": "string",
                "description": "Account kind hint: snark_fee, zkapp, faucet, echo, custom"
              }
            }
          }
        },
        "extra_accounts_file": {
          "type": "string",
          "description": "Path to a JSON file containing an array of extra genesis-ledger account objects (each with pk, balance, sk, delegate). Merged into genesis_ledger.json and daemon.json during materialization. Matches bash --extra-genesis-account-file semantics."
        }
      }
    },
    "logging": {
      "type": "object",
      "description": "Grouped log levels by output target and process role",
      "additionalProperties": false,
      "properties": {
        "console": {
          "type": "object",
          "description": "Console (stderr) log levels per process role",
          "additionalProperties": false,
          "properties": {
            "node": {
              "type": "string",
              "enum": ["Spam", "Trace", "Debug", "Info", "Warn", "Error", "Faulty_peer", "Fatal"],
              "default": "Warn"
            },
            "snark_worker": {
              "type": "string",
              "enum": ["Spam", "Trace", "Debug", "Info", "Warn", "Error", "Faulty_peer", "Fatal"],
              "default": "Error"
            },
            "archive": {
              "type": "string",
              "enum": ["Spam", "Trace", "Debug", "Info", "Warn", "Error", "Faulty_peer", "Fatal"],
              "default": "Warn"
            },
            "rosetta": {
              "type": "string",
              "enum": ["Spam", "Trace", "Debug", "Info", "Warn", "Error", "Faulty_peer", "Fatal"],
              "default": "Warn"
            }
          }
        },
        "file": {
          "type": "object",
          "description": "File log levels per process role",
          "additionalProperties": false,
          "properties": {
            "node": {
              "type": "string",
              "enum": ["Spam", "Trace", "Debug", "Info", "Warn", "Error", "Faulty_peer", "Fatal"],
              "default": "Info"
            },
            "snark_worker": {
              "type": "string",
              "enum": ["Spam", "Trace", "Debug", "Info", "Warn", "Error", "Faulty_peer", "Fatal"],
              "default": "Info"
            },
            "archive": {
              "type": "string",
              "enum": ["Spam", "Trace", "Debug", "Info", "Warn", "Error", "Faulty_peer", "Fatal"],
              "default": "Info"
            },
            "rosetta": {
              "type": "string",
              "enum": ["Spam", "Trace", "Debug", "Info", "Warn", "Error", "Faulty_peer", "Fatal"],
              "default": "Info"
            }
          }
        }
      }
    },
    "nodes": {
      "type": "object",
      "description": "Keyed object of daemon node definitions with capabilities",
      "additionalProperties": false,
      "patternProperties": {
        "^[a-zA-Z0-9_]+$": {
          "type": "object",
          "required": ["capabilities"],
          "additionalProperties": false,
          "properties": {
            "capabilities": {
              "type": "object",
              "description": "Node capabilities: p2p_seed, block_producer, snark_coordinator, itn_graphql",
              "additionalProperties": false,
              "properties": {
                "p2p_seed": {
                  "type": "object",
                  "description": "This node acts as a seed/peer discovery node",
                  "additionalProperties": false,
                  "properties": {}
                },
                "block_producer": {
                  "type": "object",
                  "description": "This node produces blocks",
                  "additionalProperties": false,
                  "required": ["account"],
                  "properties": {
                    "account": {
                      "type": "string",
                      "description": "Tier and index specifier, e.g. 'whale-0' means tier 'whale' index 0"
                    }
                  }
                },
                "snark_coordinator": {
                  "type": "object",
                  "description": "Snark coordinator config on this node",
                  "additionalProperties": false,
                  "properties": {
                    "fee_receiver": {
                      "type": "string",
                      "description": "Named account receiving snark fees, e.g. 'snark-fees'"
                    },
                    "fee": {
                      "type": "string",
                      "description": "Snark worker fee, e.g. '0.001mina'"
                    },
                    "work_selection": {
                      "type": "string",
                      "enum": ["seq"],
                      "default": "seq"
                    },
                    "worker_pools": {
                      "type": "object",
                      "description": "Worker pool definitions keyed by pool name",
                      "additionalProperties": {
                        "type": "object",
                        "required": ["count"],
                        "additionalProperties": false,
                        "properties": {
                          "count": { "type": "integer", "minimum": 0 },
                          "nap": {
                            "type": "string",
                            "description": "ISO-8601 duration for worker nap, e.g. 'PT1S'"
                          }
                        }
                      }
                    }
                  }
                },
                "itn_graphql": {
                  "type": "object",
                  "description": "Enable ITN GraphQL endpoint",
                  "additionalProperties": false,
                  "properties": {}
                }
              }
            },
            "peer": {
              "type": "string",
              "description": "Peer multiaddr to connect to (auto-resolved for non-seed nodes)"
            },
            "itn_keys": {
              "type": "string",
              "description": "ITN keys argument"
            },
            "demo_mode": {
              "type": "boolean",
              "description": "Run in demo mode (assumes synced without peers)"
            },
            "ports": {
              "type": "object",
              "description": "Pinned port overrides",
              "additionalProperties": false,
              "properties": {
                "client": { "type": "integer" },
                "rest": { "type": "integer" },
                "external": { "type": "integer" },
                "metrics": { "type": "integer" },
                "libp2p_metrics": { "type": "integer" },
                "itn_graphql": { "type": "integer" }
              }
            },
            "extra_args": {
              "type": "array",
              "items": { "type": "string" },
              "description": "Extra CLI arguments to append to daemon command"
            }
          }
        }
      }
    },
    "services": {
      "type": "object",
      "description": "Keyed object of service definitions",
      "additionalProperties": false,
      "properties": {
        "archive": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "port": { "type": "integer" },
            "binary": { "type": "string" },
            "postgres": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "host": { "type": "string", "default": "localhost" },
                "port": { "type": "integer", "default": 5432 },
                "user": { "type": "string" },
                "password": { "type": "string" },
                "db": { "type": "string", "default": "archive" }
              }
            }
          }
        },
        "rosetta": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "port": { "type": "integer" },
            "binary": { "type": "string" },
            "max_db_pool_size": { "type": "integer", "default": 64 }
          }
        }
      }
    },
    "workloads": {
      "type": "object",
      "description": "Workload definitions keyed by workload name to run after network start",
      "additionalProperties": {
        "type": "object",
        "additionalProperties": false,
        "required": ["type"],
        "properties": {
          "type": {
            "type": "string",
            "enum": ["echo", "value_transfer", "zkapp", "itn_max_cost"]
          },
          "start": {
            "type": "string",
            "enum": ["immediate", "after_graphql_ready", "after_sync", "manual"],
            "default": "immediate"
          },
          "config": { "type": "object" }
        },
        "if": {
          "properties": { "type": { "const": "echo" } }
        },
        "then": {
          "properties": {
            "config": {
              "type": "object",
              "required": ["argv"],
              "additionalProperties": false,
              "properties": {
                "argv": {
                  "type": "array",
                  "items": { "type": "string" },
                  "minItems": 1
                },
                "env": {
                  "type": "object",
                  "additionalProperties": { "type": "string" }
                },
                "success_exits_keep_network": {
                  "type": "boolean",
                  "default": true
                }
              }
            }
          }
        },
        "else": {
          "if": {
            "properties": { "type": { "const": "value_transfer" } }
          },
          "then": {
            "required": ["config"],
            "properties": {
              "config": {
                "type": "object",
                "required": ["sender"],
                "additionalProperties": false,
                "properties": {
                  "sender": {
                    "type": "string",
                    "description": "Account ref string like 'whale-0' or 'fish-0'"
                  },
                  "receiver": {
                    "type": "string",
                    "description": "Account ref string; defaults to sender"
                  },
                  "amount": {
                    "type": "string",
                    "description": "Amount string; default '1'"
                  },
                  "interval_seconds": {
                    "type": "number",
                    "minimum": 0,
                    "description": "Interval between sends in seconds; default 10"
                  },
                  "count": {
                    "type": "integer",
                    "minimum": 1,
                    "description": "Number of sends; if omitted runs indefinitely"
                  },
                  "success_exits_keep_network": {
                    "type": "boolean",
                    "default": true
                  }
                }
              }
            }
          },
          "else": {
            "if": {
              "properties": { "type": { "const": "zkapp" } }
            },
            "then": {
              "properties": {
                "config": {
                  "type": "object",
                  "additionalProperties": false,
                  "properties": {
                    "fee_payer_account": {
                      "type": "string",
                      "description": "Offline account ref for fee payer, e.g. 'whale-0'; default 'whale-0'"
                    },
                    "sender_account": {
                      "type": "string",
                      "description": "Offline account ref for sender, e.g. 'whale-1'; default 'whale-1'"
                    },
                    "transfer_amount": {
                      "type": "string",
                      "description": "Amount for transfer-funds; default '1'"
                    },
                    "receiver_amount": {
                      "type": "string",
                      "description": "Receiver amount for create-zkapp-account; default '1000'"
                    },
                    "fee": {
                      "type": "string",
                      "description": "Fee for zkApp commands; default '5'"
                    },
                    "interval_seconds": {
                      "type": "number",
                      "minimum": 0,
                      "description": "Interval between iterations in seconds; default 10"
                    },
                    "count": {
                      "type": "integer",
                      "minimum": 1,
                      "description": "Number of transfer+update iterations; if omitted runs indefinitely"
                    },
                    "create_account": {
                      "type": "boolean",
                      "description": "Whether to create the zkApp account first; default true"
                    },
                    "success_exits_keep_network": {
                      "type": "boolean",
                      "description": "Whether exit 0 keeps the network alive; default true"
                    }
                  }
                }
              }
            },
            "else": {
              "if": {
                "properties": { "type": { "const": "itn_max_cost" } }
              },
              "then": {
                "required": ["config"],
                "properties": {
                  "config": {
                    "type": "object",
                    "required": ["duration_min"],
                    "additionalProperties": false,
                    "properties": {
                      "duration_min": {
                        "type": "integer",
                        "minimum": 1,
                        "description": "Duration in minutes for which to schedule zkApp commands"
                      },
                      "tps": {
                        "oneOf": [
                          { "type": "number", "exclusiveMinimum": 0 },
                          { "type": "string", "const": "auto" },
                          { "type": "null" }
                        ],
                        "description": "Target transactions per second; absent, null, or 'auto' means compute from block_window_duration_ms"
                      },
                      "fee_payer_account": {
                        "type": "string",
                        "description": "Offline fee-payer account ref, e.g. 'whale-0'; default 'whale-0'"
                      },
                      "num_zkapps_to_deploy": {
                        "type": "integer",
                        "minimum": 0,
                        "description": "Number of zkApp accounts to deploy; default 2"
                      },
                      "max_cost_num_updates": {
                        "type": "integer",
                        "minimum": 0,
                        "description": "Number of proof-authorised account updates per command; default 7"
                      },
                      "num_new_accounts": {
                        "type": "integer",
                        "minimum": 0,
                        "description": "Number of new accounts per command; default 0"
                      },
                      "account_queue_size": {
                        "type": "integer",
                        "minimum": 0,
                        "description": "Account queue size; default 0"
                      },
                      "memo_prefix": {
                        "type": "string",
                        "description": "Memo prefix for scheduled commands; default 'maxcost'"
                      },
                      "no_precondition": {
                        "type": "boolean",
                        "description": "Disable account preconditions; default false"
                      },
                      "min_balance_change": {
                        "type": "string",
                        "description": "Raw nanomina uint64 lower bound; default '0'"
                      },
                      "max_balance_change": {
                        "type": "string",
                        "description": "Raw nanomina uint64 upper bound; default '1000000000'"
                      },
                      "min_new_zkapp_balance": {
                        "type": "string",
                        "description": "Raw nanomina uint64 lower bound for new zkApps; default '1000000000'"
                      },
                      "max_new_zkapp_balance": {
                        "type": "string",
                        "description": "Raw nanomina uint64 upper bound for new zkApps; default '2000000000'"
                      },
                      "init_balance": {
                        "type": "string",
                        "description": "Raw nanomina uint64 initial balance; default '5000000000'"
                      },
                      "min_fee": {
                        "type": "string",
                        "description": "Raw nanomina uint64 minimum fee; default '1000000000'"
                      },
                      "max_fee": {
                        "type": "string",
                        "description": "Raw nanomina uint64 maximum fee; default '2000000000'"
                      },
                      "deployment_fee": {
                        "type": "string",
                        "description": "Raw nanomina uint64 fee for deployment phase; default '1000000000'"
                      },
                      "success_exits_keep_network": {
                        "type": "boolean",
                        "description": "Whether exit 0 keeps the network alive; default true"
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "state": {
      "type": "object",
      "description": "State root, mode, and genesis timestamp",
      "additionalProperties": false,
      "properties": {
        "root": {
          "type": "string",
          "description": "State root directory. Default: .mina-local-network/<topology-or-preset-name>/ relative to repo root."
        },
        "mode": {
          "type": "string",
          "description": "State mode: 'reset' wipes and regenerates, 'keep' preserves existing state",
          "enum": ["reset", "keep"],
          "default": "reset"
        },
        "genesis_timestamp": {
          "type": "object",
          "description": "Genesis state timestamp configuration",
          "additionalProperties": false,
          "properties": {
            "delay": {
              "type": "string",
              "description": "ISO-8601 duration to delay genesis, e.g. 'PT120S' for 120 seconds"
            },
            "value": {
              "type": "string",
              "format": "date-time",
              "description": "Absolute genesis timestamp in RFC3339 format, e.g. '2026-07-10T12:00:00Z'. When present, 'delay' is ignored."
            }
          }
        },
        "extra_files_root": {
          "type": "string",
          "description": "Path to a directory whose contents are recursively copied into the state root after generated files exist but before the manifest is written. Matches bash --extra-files-root semantics."
        }
      }
    },
    "binaries": {
      "type": "object",
      "description": "Default binary paths",
      "additionalProperties": false,
      "properties": {
        "mina": { "type": "string" },
        "archive": { "type": "string" },
        "rosetta": { "type": "string" },
        "zkapp": { "type": "string" }
      }
    }
  }
}
