# Docker images
MINA_DAEMON_IMAGE=gcr.io/o1labs-192920/mina-daemon:3.3.0-alpha1-6929a7e-bullseye-devnet

# Network
MINA_NETWORK=devnet
MINA_PEERLIST_URL=https://bootnodes.minaprotocol.com/networks/devnet.txt

# Required: passphrase for the libp2p key
MINA_LIBP2P_PASS=

# Mina daemon ports
MINA_REST_PORT=3085
MINA_P2P_PORT=8302
