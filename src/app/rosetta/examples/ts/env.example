# Copy to .env and fill in values for the examples that need them.

# Rosetta endpoint. Default port from docker-compose stack is 3087.
ROSETTA_URL=http://localhost:3087

# Network name advertised by your Rosetta. Must match what /network/list returns.
NETWORK=devnet

# An address you want to query. Used by account-balance.ts and track-deposits.ts.
TEST_ADDRESS=B62qiy32p8kAKnny8ZFwoMhyUjYbuQ7nYHcSEqCvrR7sM4f9F4eNJMW

# Where to start scanning. Used by scan-blocks.ts and track-deposits.ts.
# Set to 0 to start from chain tip.
START_HEIGHT=0

# --- send-transaction.ts / offline-sign.ts ---

# Hex-encoded private key in mina-signer format.
# Generate one with: node -e "console.log(new (require('mina-signer'))({network:'testnet'}).genKeys())"
SENDER_PRIVATE_KEY=

# Base58 sender address (derived from SENDER_PRIVATE_KEY).
SENDER_ADDRESS=

# Hex-encoded sender public key. Required for offline-sign.ts (so the online
# host can build payloads without seeing the private key).
# Derive from SENDER_ADDRESS via mina-signer's publicKeyToRaw.
SENDER_PUBLIC_KEY=

# Base58 receiver address.
RECEIVER_ADDRESS=

# Amounts in nanomina (1 MINA = 1_000_000_000 nanomina).
TRANSFER_AMOUNT=1000000000
TRANSFER_FEE=10000000
