# Postgres
POSTGRES_DB=archive
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_PORT=5433

# Docker images
MINA_DAEMON_IMAGE=minaprotocol/mina-daemon:3.3.1-7b34378-noble-mainnet
MINA_ARCHIVE_IMAGE=minaprotocol/mina-archive:3.3.1-7b34378-noble-mainnet
MINA_ROSETTA_IMAGE=minaprotocol/mina-rosetta:3.3.1-7b34378-noble-mainnet
# Network-agnostic; --network is passed at runtime via bootstrap_db command
MINA_BOOTSTRAP_IMAGE=minaprotocol/mina-bootstrap:3.3.1-7b34378-noble

# Network
MINA_NETWORK=mainnet
MINA_PEERLIST_URL=https://bootnodes.minaprotocol.com/networks/mainnet.txt
MINA_LIBP2P_PASS=

# Mina daemon ports
MINA_REST_PORT=3085
MINA_P2P_PORT=8302

# Mina archive
MINA_ARCHIVE_PORT=3086

# Mina rosetta
MINA_ROSETTA_PORT=3087
MINA_ROSETTA_MAX_DB_POOL_SIZE=80
MINA_ROSETTA_PG_DATA_INTERVAL=30

# Missing blocks guardian
GUARDIAN_PRECOMPUTED_BLOCKS_URL=https://storage.googleapis.com/mina_network_block_data/mainnet
# GUARDIAN_SLEEP_INTERVAL=600  # optional, defaults to 600

# Archive DB bootstrap is handled by mina-bootstrap (MINA_BOOTSTRAP_IMAGE
# above). It downloads the dump from the GCS bucket, restores it into
# Postgres, and applies the recommended tuning — all driven by the
# command flags on the bootstrap_db service in docker-compose.yml.
