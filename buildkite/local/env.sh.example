#!/bin/bash

# Custom pipeline parameters for local Buildkite job execution.
# Copy this file to env.sh and modify as needed:
#   cp env.sh.example env.sh
#
# Usage: ./run_job.sh --env-file ./env.sh <job-name>
#
# Only pipeline-specific variables belong here.
# All BUILDKITE_* variables are auto-computed by run_job.sh from git state.
# You can still override any BUILDKITE_* var here if needed.

# --- Pipeline parameters ---
export REPO="Nightly"
export NETWORK="Devnet"
export VERSION="4.0.0-fake-e44eefb"
export CODENAMES="Noble"
export GENESIS_TIMESTAMP="2026-01-27T19:30:00Z"
export CONFIG_JSON_GZ_URL="https://storage.googleapis.com/o1labs-gitops-infrastructure/devnet/devnet-state-dump-3NLyZQFbXnnoDmpwhjY7rGgRBxL7XCmfigfa1YcAdP4htzxpPdB3-1b0e146b085208ad8c125e96516c0953d16ff879d10bd7b3a0a63dbc14530841.json.gz"
export MINA_LEDGER_S3_BUCKET="https://s3-us-west-2.amazonaws.com/snark-keys.o1test.net"
export PRECOMPUTED_FORK_BLOCK_PREFIX="gs://mina_network_block_data/devnet"

